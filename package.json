{
  "name": "@cplieger/actions",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./src/*": "./src/*"
  },
  "scripts": {
    "typecheck": "tsgo -project tsconfig.json",
    "typecheck:tests": "tsgo -project tsconfig.test.json",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "fast-check": "4.8.0",
    "happy-dom": "20.9.0",
    "prettier": "3.8.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.8"
  },
  "description": "Declarative async UI-action framework for TypeScript",
  "license": "GPL-3.0-or-later",
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cplieger/actions.git"
  },
  "files": [
    "src/",
    "!src/**/*.test.ts",
    "!src/**/__test-helpers__",
    "!src/**/fc-strict-setup.ts",
    "jsr.json"
  ]
}
